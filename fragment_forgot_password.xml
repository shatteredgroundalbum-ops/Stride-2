<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView android:id="@+id/bgPortrait" android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/bg_login_portrait" android:scaleType="centerCrop" android:visibility="visible"/>
    <ImageView android:id="@+id/bgLandscape" android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/bg_login_landscape" android:scaleType="centerCrop" android:visibility="gone"/>

    <!-- PORTRAIT -->
    <LinearLayout android:id="@+id/portraitLayout" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:visibility="visible">
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="45"/>
        <ScrollView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="55" android:fillViewport="true" android:scrollbars="none">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal" android:paddingStart="24dp" android:paddingEnd="24dp" android:paddingTop="40dp" android:paddingBottom="32dp">

                <ImageView android:layout_width="180dp" android:layout_height="180dp" android:src="@drawable/img_logo" android:scaleType="fitCenter" android:layout_marginBottom="12dp"/>
                <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/img_forgot" android:scaleType="fitStart" android:adjustViewBounds="true" android:layout_marginBottom="20dp"/>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/emailLayoutP" style="@style/StrideInputLayout" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/enter_email_hint" android:layout_marginBottom="20dp" app:startIconDrawable="@android:drawable/ic_dialog_email" app:startIconTint="@color/green_light">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/emailInputP" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textEmailAddress" android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton android:id="@+id/btnSendP" style="@style/StrideButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_send_reset" android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton android:id="@+id/btnBackLoginP" style="@style/StrideButtonOutline" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_back_login"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- LANDSCAPE -->
    <LinearLayout android:id="@+id/landscapeLayout" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:visibility="gone">
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="42" android:gravity="center" android:padding="24dp">
            <ImageView android:layout_width="220dp" android:layout_height="220dp" android:src="@drawable/img_logo" android:scaleType="fitCenter"/>
        </LinearLayout>
        <ScrollView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="58" android:fillViewport="true" android:scrollbars="none">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal" android:paddingStart="24dp" android:paddingEnd="24dp" android:paddingTop="24dp" android:paddingBottom="24dp">

                <ImageView android:layout_width="match_parent" android:layout_height="wrap_content" android:src="@drawable/img_forgot" android:scaleType="fitStart" android:adjustViewBounds="true" android:layout_marginBottom="16dp"/>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/emailLayoutL" style="@style/StrideInputLayout" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/enter_email_hint" android:layout_marginBottom="16dp" app:startIconDrawable="@android:drawable/ic_dialog_email" app:startIconTint="@color/green_light">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/emailInputL" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textEmailAddress" android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton android:id="@+id/btnSendL" style="@style/StrideButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_send_reset" android:layout_marginBottom="10dp"/>

                <com.google.android.material.button.MaterialButton android:id="@+id/btnBackLoginL" style="@style/StrideButtonOutline" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_back_login"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</FrameLayout>
