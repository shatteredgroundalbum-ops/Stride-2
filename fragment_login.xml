<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Portrait BG -->
    <ImageView
        android:id="@+id/bgPortrait"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_login_portrait"
        android:scaleType="centerCrop"
        android:visibility="visible" />

    <!-- Landscape BG -->
    <ImageView
        android:id="@+id/bgLandscape"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_login_landscape"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- PORTRAIT layout -->
    <LinearLayout
        android:id="@+id/portraitLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="visible">

        <!-- Left spacer (45%) -->
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="45"/>

        <!-- Right form panel (55%) -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="55"
            android:fillViewport="true"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="40dp"
                android:paddingBottom="32dp">

                <ImageView
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:src="@drawable/img_logo"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="12dp"/>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:src="@drawable/img_welcome_back"
                    android:scaleType="fitStart"
                    android:adjustViewBounds="true"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/emailLayoutP"
                    style="@style/StrideInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/email_hint"
                    android:layout_marginBottom="12dp"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="@color/green_light">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emailInputP"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/passwordLayoutP"
                    style="@style/StrideInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/password_hint"
                    android:layout_marginBottom="8dp"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="@color/green_light"
                    app:endIconMode="password_toggle">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/passwordInputP"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/forgotPasswordP"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password"
                    android:textColor="@color/green_med"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLoginP"
                    style="@style/StrideButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_login"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="— OR —"
                    android:gravity="center"
                    android:textColor="@color/gray_hint"
                    android:layout_marginBottom="12dp"/>

                <!-- Social buttons row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGoogleP"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="G"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#4285F4"
                        android:layout_marginEnd="8dp"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/gray_border"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAppleP"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text=""
                        android:layout_marginEnd="8dp"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/gray_border"
                        app:icon="@android:drawable/ic_menu_close_clear_cancel"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFacebookP"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="f"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1877F2"
                        android:layout_marginEnd="8dp"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/gray_border"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnInstagramP"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="In"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#E1306C"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/gray_border"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't have an account?  "
                        android:textColor="@color/gray_text"/>
                    <TextView
                        android:id="@+id/goToCreateP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Create Account"
                        android:textColor="@color/green_med"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- LANDSCAPE layout -->
    <LinearLayout
        android:id="@+id/landscapeLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- Left logo panel (42%) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="42"
            android:gravity="center"
            android:padding="24dp">
            <ImageView
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:src="@drawable/img_logo"
                android:scaleType="fitCenter"/>
        </LinearLayout>

        <!-- Right form panel (58%) -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="58"
            android:fillViewport="true"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:src="@drawable/img_welcome_back"
                    android:scaleType="fitStart"
                    android:adjustViewBounds="true"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/emailLayoutL"
                    style="@style/StrideInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/email_hint"
                    android:layout_marginBottom="10dp"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="@color/green_light">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emailInputL"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/passwordLayoutL"
                    style="@style/StrideInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/password_hint"
                    android:layout_marginBottom="6dp"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="@color/green_light"
                    app:endIconMode="password_toggle">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/passwordInputL"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/forgotPasswordL"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password"
                    android:textColor="@color/green_med"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLoginL"
                    style="@style/StrideButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_login"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="— OR —"
                    android:gravity="center"
                    android:textColor="@color/gray_hint"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="10dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGoogleL"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="G"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#4285F4"
                        android:layout_marginEnd="8dp"
                        app:cornerRadius="10dp"
                        app:strokeColor="@color/gray_border"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAppleL"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginEnd="8dp"
                        app:cornerRadius="10dp"
                        app:strokeColor="@color/gray_border"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFacebookL"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="f"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1877F2"
                        android:layout_marginEnd="8dp"
                        app:cornerRadius="10dp"
                        app:strokeColor="@color/gray_border"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnInstagramL"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="In"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#E1306C"
                        app:cornerRadius="10dp"
                        app:strokeColor="@color/gray_border"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't have an account?  "
                        android:textColor="@color/gray_text"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/goToCreateL"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Create Account"
                        android:textColor="@color/green_med"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</FrameLayout>
